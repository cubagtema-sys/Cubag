# =============================================
#  CUBAG PLATFORM — Backend Environment Config
#  Copy this file to .env and fill in real values
# =============================================

# Flask Server
FLASK_APP=server.py
FLASK_ENV=production
PORT=5000
SECRET_KEY=change_this_to_a_random_string

# Database (PostgreSQL) — Railway provides DATABASE_URL automatically
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Customs
DB_USER=postgres
DB_PASSWORD=your_db_password

# Email (SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@email.com
SMTP_PASS=your_email_password

# JWT
JWT_SECRET_KEY=change_this_to_a_random_string
JWT_ACCESS_TOKEN_EXPIRES=604800

# Frontend URL (CORS)
CLIENT_URL=https://your-frontend-url.com

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=sk_live_your_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
PAYSTACK_CALLBACK_URL=https://your-app.railway.app
